#***********************************************************************
# Grammar App - .htaccess URL Rewriting
# 
# Description: Enables clean URLs without index.php in the path.
# Routes all requests through index.php except for existing files/directories.
#***********************************************************************

RewriteEngine On
RewriteBase /grammar-app/public/

# If the request is for an existing file, don't rewrite
RewriteCond %{REQUEST_FILENAME} !-f

# If the request is for an existing directory, don't rewrite
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]